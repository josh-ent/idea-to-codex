{
  "name": "idea-to-codex",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:server": "tsx watch src/index.ts",
    "dev:web": "vite --config web/vite.config.ts",
    "build": "npm run build:server && npm run build:web",
    "build:server": "tsc -p tsconfig.json",
    "build:web": "vite build --config web/vite.config.ts",
    "start": "node dist/index.js",
    "bootstrap": "tsx src/cli.ts bootstrap",
    "validate": "tsx src/cli.ts validate",
    "package:plan": "tsx src/cli.ts package plan",
    "package:execution": "tsx src/cli.ts package execution",
    "review": "tsx src/cli.ts review",
    "test": "vitest run"
  },
  "dependencies": {
    "express": "^5.1.0",
    "gray-matter": "^4.0.3",
    "@primeuix/themes": "^2.0.3",
    "pinia": "^3.0.4",
    "primeicons": "^7.0.0",
    "primevue": "^4.5.4",
    "vue": "^3.5.30",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/node": "^24.6.1",
    "@types/supertest": "^6.0.3",
    "@vitejs/plugin-vue": "^6.0.5",
    "supertest": "^7.1.4",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vite": "^8.0.0",
    "vitest": "^3.2.4"
  }
}
